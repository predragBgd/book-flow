FLASK_APP=run.py
FLASK_ENV=production

# Generate strong random strings for production (openssl rand -hex 32)
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-in-production

# Set by Render/Railway when PostgreSQL is linked
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/bookflow

# Comma-separated frontend URLs (no trailing slash)
# Example: https://bookflow.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=https://your-frontend.vercel.app
